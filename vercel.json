{
  "framework": "vite",
  "installCommand": "npm install --prefix frontend --legacy-peer-deps",
  "buildCommand": "npm run build --prefix frontend",
  "outputDirectory": "frontend/dist",
  "env": {
    "VITE_API_URL": {
      "value": ""
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
