# ================================================================
# Terra Pravah - Environment Configuration Template
# ================================================================
# 
# Copy this file to .env and update the values:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env to version control!
# ================================================================

# ==================== Application ====================
FLASK_ENV=development
# FLASK_ENV=production

# Secret keys - CHANGE THESE IN PRODUCTION!
SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-this-in-production

# Application version
APP_VERSION=2.0.0

# ==================== Database ====================
# SQLite (Development)
DATABASE_URL=sqlite:///database/terrapravah.db

# PostgreSQL (Production)
# DATABASE_URL=postgresql://terrapravah:password@localhost:5432/terrapravah

# PostgreSQL credentials (for docker-compose)
POSTGRES_DB=terrapravah
POSTGRES_USER=terrapravah
POSTGRES_PASSWORD=changeme-in-production

# ==================== Redis ====================
REDIS_URL=redis://localhost:6379/0

# ==================== Ports ====================
BACKEND_PORT=5000
FRONTEND_PORT=3000
REDIS_PORT=6379
POSTGRES_PORT=5432

# ==================== CORS ====================
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ==================== WhiteboxTools ====================
WBT_PATH=/opt/WBT

# ==================== Email (Optional) ====================
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@terrapravah.com

# ==================== Storage ====================
MAX_FILE_SIZE_MB=5000
UPLOAD_FOLDER=uploads
RESULTS_FOLDER=results

# ==================== File Format Support ====================
# Enable Cloud Optimized GeoTIFF (COG) support
ENABLE_COG_SUPPORT=true

# Enable sample data for demo projects
ENABLE_SAMPLE_DATA=true

# ==================== Default Admin User ====================
# Set these ONLY if you want to auto-create an admin user on first run
# Leave commented out for production deployments
# CREATE_DEFAULT_ADMIN=true
# DEFAULT_ADMIN_EMAIL=admin@yourcompany.com
# DEFAULT_ADMIN_PASSWORD=your-secure-password-here

# ==================== API Keys (Optional) ====================
# Stripe (for billing)
STRIPE_API_KEY=sk_test_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx

# Google OAuth (optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ==================== Logging ====================
LOG_LEVEL=INFO
# LOG_LEVEL=DEBUG

# ==================== Frontend ====================
VITE_API_URL=http://localhost:5000

# ==================== Regional Settings ====================
DEFAULT_CLIMATE_REGION=delhi_ncr
DEFAULT_DESIGN_STORM_YEARS=10
DEFAULT_RUNOFF_COEFFICIENT=0.7
