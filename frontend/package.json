{
  "name": "terra-pravah-frontend",
  "version": "1.0.0",
  "private": true,
  "description": "Terra Pravah - AI-Powered Drainage Design Platform Frontend",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint src --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,css,scss,json}\"",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "deploy:vercel": "vercel --prod",
    "deploy:preview": "vercel",
    "build:prod": "npm run lint && npm run build",
    "build:analyze": "vite build --mode analyze"
  },
  "dependencies": {
    "@emotion/react": "^11.11.0",
    "@emotion/styled": "^11.11.0",
    "@headlessui/react": "^1.7.15",
    "@heroicons/react": "^2.0.18",
    "@react-three/drei": "^9.77.0",
    "@react-three/fiber": "^8.13.3",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^4.29.19",
    "axios": "^1.4.0",
    "chart.js": "^4.3.0",
    "clsx": "^1.2.1",
    "date-fns": "^2.30.0",
    "framer-motion": "^10.12.16",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.563.0",
    "mapbox-gl": "^2.15.0",
    "plotly.js": "^2.24.2",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.2.0",
    "react-dropzone": "^14.2.3",
    "react-hot-toast": "^2.4.1",
    "react-icons": "^4.10.1",
    "react-leaflet": "^4.2.1",
    "react-plotly.js": "^2.6.0",
    "react-router-dom": "^6.13.0",
    "recharts": "^2.7.2",
    "socket.io-client": "^4.6.2",
    "three": "^0.153.0",
    "zustand": "^4.3.8"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.3",
    "@types/node": "^20.3.1",
    "@types/react": "^18.2.13",
    "@types/react-dom": "^18.2.6",
    "@types/three": "^0.152.1",
    "@typescript-eslint/eslint-plugin": "^5.60.0",
    "@typescript-eslint/parser": "^5.60.0",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.14",
    "eslint": "^8.43.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "postcss": "^8.4.24",
    "prettier": "^2.8.8",
    "tailwindcss": "^3.3.2",
    "typescript": "^5.1.3",
    "vite": "^4.3.9",
    "vitest": "^0.32.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
