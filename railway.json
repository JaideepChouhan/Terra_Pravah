{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "rootDirectory": "."
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "gunicorn -w 4 -b 0.0.0.0:${PORT:-5000} -k geventwebsockethandler --timeout 120 --access-logfile - --error-logfile - backend.app:app",
    "restartPolicyMaxRetries": 5,
    "restartPolicyWindowSeconds": 60
  },
  "plugins": [
    {
      "source": "https://github.com/railwayapp/starters/tree/main/plugins/postgres"
    },
    {
      "source": "https://github.com/railwayapp/starters/tree/main/plugins/redis"
    }
  ]
}
