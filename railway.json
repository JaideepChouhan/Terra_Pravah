{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "rootDirectory": "."
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "gunicorn --factory --bind 0.0.0.0:${PORT:-5000} --workers 4 --threads 2 --timeout 120 backend.app:create_app",
    "restartPolicyMaxRetries": 5,
    "restartPolicyWindowSeconds": 60
  },
  "plugins": [
    {
      "source": "https://github.com/railwayapp/starters/tree/main/plugins/postgres"
    },
    {
      "source": "https://github.com/railwayapp/starters/tree/main/plugins/redis"
    }
  ]
}
