# ================================================================
# Terra Pravah - Complete Environment Configuration
# ================================================================
# 
# PRODUCTION DEPLOYMENT GUIDE:
# 1. Copy this file: cp .env.example .env
# 2. Update all values with your production secrets
# 3. NEVER commit .env to version control!
# 4. For Vercel: Add these to Vercel project settings
# 5. For Railway: Add these to Railway environment variables
#
# ================================================================

# ==================== APPLICATION CONFIGURATION ====================
FLASK_ENV=production
APP_VERSION=2.0.0
APP_NAME=Terra Pravah

# Secret keys - GENERATE NEW SECURE KEYS FOR PRODUCTION!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-change-this-in-production-generate-new
JWT_SECRET_KEY=your-jwt-secret-key-change-this-in-production-generate-new

# ==================== DATABASE CONFIGURATION ====================
# PostgreSQL Connection String (Production)
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://terrapravah:password@localhost:5432/terrapravah

# Alternative for Railway (auto-populated):
# DATABASE_URL=${{ secrets.DATABASE_URL }}
# Or Railway uses: POSTGRES_URL=${{ secrets.POSTGRES_URL }}

# If using SQLite (Development only):
# DATABASE_URL=sqlite:///database/terrapravah.db

# PostgreSQL Connection Pool Settings
SQLALCHEMY_POOL_SIZE=10
SQLALCHEMY_MAX_OVERFLOW=20
SQLALCHEMY_POOL_RECYCLE=60

# ==================== REDIS CONFIGURATION ====================
# Redis Connection String
# Format: redis://:password@host:port/database
REDIS_URL=redis://localhost:6379/0

# Alternative services:
# Redis Cloud: redis://:password@redis-server:port
# Railway Redis: ${{ secrets.REDIS_URL }}

# ==================== CORS CONFIGURATION ====================
# Frontend URLs allowed to access backend API
# Comma-separated list
CORS_ORIGINS=https://terrapravah.com,https://www.terrapravah.com,https://terrapravah.vercel.app

# ==================== FRONTEND CONFIGURATION ====================
# Frontend URL for redirects and email links
FRONTEND_URL=https://terrapravah.com

# Ports (for local development only)
BACKEND_PORT=5000
FRONTEND_PORT=3000

# ==================== JWT AUTHENTICATION ====================
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=2592000
JWT_TOKEN_LOCATION=headers,cookies
JWT_COOKIE_SECURE=true
JWT_COOKIE_HTTPONLY=true
JWT_COOKIE_SAMESITE=Lax

# ==================== OAUTH PROVIDERS ====================
# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://api.terrapravah.com/api/auth/google/callback

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=https://api.terrapravah.com/api/auth/github/callback

# ==================== EMAIL CONFIGURATION ====================
# SendGrid (Recommended for production)
MAIL_SERVER=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=apikey
MAIL_PASSWORD=your-sendgrid-api-key
MAIL_DEFAULT_SENDER=noreply@terrapravah.com

# Alternative: Gmail SMTP
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USE_TLS=true
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-app-specific-password

# ==================== FILE UPLOAD CONFIGURATION ====================
# Maximum file size in MB (for large LiDAR files)
MAX_FILE_SIZE_MB=5000

# Storage backend: local, s3, gcs
STORAGE_BACKEND=local

# For S3 Storage:
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_BUCKET_NAME=terrapravah-storage
AWS_REGION=us-east-1

# For Railway ephemeral filesystem (automatically /tmp):
# UPLOAD_FOLDER=/tmp/uploads
# RESULTS_FOLDER=/tmp/results

# ==================== STRIPE BILLING ====================
STRIPE_PUBLIC_KEY=pk_live_your-stripe-public-key
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# ==================== ANTHROPIC API (Claude AI) ====================
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# ==================== CELERY & BACKGROUND JOBS ====================
CELERY_BROKER_URL=${REDIS_URL}
CELERY_RESULT_BACKEND=${REDIS_URL}

# ==================== RATE LIMITING ====================
RATELIMIT_DEFAULT=200/hour
RATELIMIT_STORAGE_URL=${REDIS_URL}

# ==================== ADMIN CONFIGURATION ====================
# Comma-separated list of admin email addresses
ADMIN_EMAILS=admin@terrapravah.com,support@terrapravah.com

# Default admin user (for initial setup)
CREATE_DEFAULT_ADMIN=false
DEFAULT_ADMIN_EMAIL=admin@terrapravah.com
DEFAULT_ADMIN_PASSWORD=change-this-after-first-login

# ==================== FEATURE FLAGS ====================
ENABLE_AI_ASSISTANT=true
ENABLE_COLLABORATION=true
ENABLE_MARKETPLACE=false
ENABLE_COG_SUPPORT=true
ENABLE_SAMPLE_DATA=true

# ==================== LOGGING ====================
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# ==================== WHITEBOXTOOLS ====================
WBT_PATH=/opt/WBT

# ==================== DEPLOYMENT PLATFORM ====================
# Railway specific:
RAILWAY_ENVIRONMENT_NAME=production

# Vercel specific:
VERCEL_ENV=production
VERCEL_REGION=iad1

# ==================== SECURITY ====================
# Session configuration
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax

# HSTS Header
HSTS_MAX_AGE=31536000

# ==================== MONITORING & ANALYTICS ====================
SENTRY_DSN=your-sentry-dsn
SENTRY_ENV=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# ==================== CUSTOM DOMAIN ====================
DOMAIN_NAME=terrapravah.com
API_DOMAIN=api.terrapravah.com
